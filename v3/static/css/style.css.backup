:root {
    --bg-dark: #000;
    --bg-darker: #0b0b0b;
    --bg-primary: #111;
    --bg-secondary: #1a1a1a;
    --bg-tertiary: #222;
    --bg-hover: #2a2a2a;
    --bg-active: #3a3a3a;
    --border-color: #333;
    --border-light: #444;
    --text-primary: #eee;
    --text-secondary: #ddd;
    --text-muted: #aaa;
    --text-dim: #888;
    --color-success: #28a745;
    --color-success-dark: #218838;
    --color-danger: #dc3545;
    --color-danger-dark: #c82333;
    --color-warning: #ffc107;
    --color-secondary: #6c757d;
    --color-secondary-dark: #5a6268;
    --gradient-bg: linear-gradient(180deg, #1a1a1a 0%, #111 100%);
    --gradient-success: linear-gradient(180deg, #2ecc71 0%, #28a745 100%);
    --gradient-danger: linear-gradient(180deg, #e74c3c 0%, #dc3545 100%);
    --gradient-secondary: linear-gradient(180deg, #7f8c8d 0%, #6c757d 100%);
    --gradient-audio: linear-gradient(180deg, #34495e 0%, #2c3e50 100%);
    --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 3px 6px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 4px 12px rgba(0, 0, 0, 0.5);
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 8px;
    --transition-fast: all 0.2s;
}

* {
    box-sizing: border-box;
}

body {
    font-family: system-ui, Arial, sans-serif;
    background: var(--bg-dark);
    color: var(--text-primary);
    margin: 0;
    display: flex;
    flex-direction: column;
    height: 100vh;
}

/* Controles superiores - Topbar */
#controls {
    display: flex;
    gap: 12px;
    padding: 12px 16px;
    background: var(--gradient-bg);
    border-bottom: 2px solid var(--bg-hover);
    align-items: center;
    box-shadow: var(--shadow-sm);
    flex-wrap: wrap;
    min-height: 56px;
}

#controls button {
    padding: 8px 16px;
    font-size: 13px;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 500;
    transition: var(--transition-fast);
    white-space: nowrap;
}

#controls button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.controls-divider {
    width: 1px;
    height: 32px;
    background: linear-gradient(180deg, transparent 0%, var(--border-light) 20%, var(--border-light) 80%, transparent 100%);
    margin: 0 4px;
}

/* Audio Controls */
#audioControl {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
    order: 6;
}

.audio-menu-btn {
    padding: 8px 12px;
    font-size: 18px;
    background: var(--gradient-audio);
    color: white;
    border: 1px solid #3a4a5a;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition-fast);
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
}

.audio-menu-btn:hover:not(:disabled) {
    background: linear-gradient(180deg, #2c3e50 0%, #1a252f 100%);
    border-color: #555;
}

.audio-menu-btn[aria-expanded="true"] {
    background: var(--color-success);
    border-color: var(--color-success-dark);
}

.volume-control-inline {
    display: flex;
    align-items: center;
    gap: 8px;
}

#volumeSlider {
    -webkit-appearance: none;
    appearance: none;
    width: 80px;
    height: 4px;
    background: linear-gradient(to right, var(--border-color) 0%, var(--border-light) 100%);
    outline: none;
    border-radius: 2px;
    cursor: pointer;
}

#volumeSlider::-webkit-slider-thumb,
#volumeSlider::-moz-range-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: var(--color-success);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: var(--transition-fast);
    box-shadow: var(--shadow-sm);
}

#volumeSlider::-webkit-slider-thumb:hover,
#volumeSlider::-moz-range-thumb:hover {
    background: var(--color-success-dark);
    transform: scale(1.1);
}

#volumeValue {
    font-size: 11px;
    color: var(--color-success);
    min-width: 32px;
    text-align: right;
    font-weight: 600;
}

/* Audio Menu Popup */
.audio-menu-popup {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 6px;
    background: var(--gradient-bg);
    border: 1px solid #3a3a3a;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    min-width: 240px;
    z-index: 1000;
    overflow: hidden;
}

.audio-menu-popup[hidden] {
    display: none;
}

.audio-menu-header {
    padding: 10px 14px;
    background: #252525;
    border-bottom: 1px solid var(--border-color);
    font-weight: 600;
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.audio-menu-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 13px;
    transition: var(--transition-fast);
    width: 100%;
    text-align: left;
}

.audio-menu-item:hover {
    background: var(--bg-hover);
}

.audio-menu-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: var(--color-success);
}

.audio-menu-item input[type="checkbox"]:disabled {
    cursor: not-allowed;
    opacity: 0.5;
}

.audio-menu-item:has(input:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
}

.audio-status {
    margin-left: auto;
    font-size: 11px;
    color: var(--color-success);
}

.audio-menu-divider {
    height: 1px;
    background: var(--border-color);
    margin: 6px 0;
}

.audio-menu-info {
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    font-size: 11px;
    color: var(--text-dim);
}

.info-row {
    display: flex;
    justify-content: space-between;
    margin: 4px 0;
}

.info-row span:last-child {
    color: var(--color-success);
    font-weight: 600;
}

/* Botões específicos */
#btnClear {
    order: 5;
    margin-left: 8px;
    background: var(--gradient-secondary);
    color: white;
    box-shadow: 0 2px 4px rgba(108, 117, 125, 0.3);
}

#btnLogin {
    background: var(--gradient-success);
    color: white;
    box-shadow: 0 2px 4px rgba(40, 167, 69, 0.3);
}

#btnDisconnect {
    background: var(--gradient-danger);
    color: white;
    box-shadow: 0 2px 4px rgba(220, 53, 69, 0.3);
}

#btnClear:hover:not(:disabled),
#btnLogin:hover:not(:disabled),
#btnDisconnect:hover:not(:disabled) {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
}

#btnClear:hover:not(:disabled) {
    background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-secondary-dark) 100%);
}

#btnLogin:hover:not(:disabled) {
    background: linear-gradient(180deg, var(--color-success) 0%, var(--color-success-dark) 100%);
}

#btnDisconnect:hover:not(:disabled) {
    background: linear-gradient(180deg, var(--color-danger) 0%, var(--color-danger-dark) 100%);
}

/* Status Indicators */
#statusIndicator,
#reconnectStatus {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border: 1px solid var(--bg-hover);
    font-size: 13px;
}

#statusIndicator {
    margin-left: auto;
    color: var(--text-muted);
    order: 20;
}

#reconnectStatus {
    color: var(--color-warning);
    order: 19;
}

#reconnectStatus[hidden] {
    display: none;
}

#btnCancelReconnect {
    padding: 6px 10px;
    font-size: 12px;
    border: none;
    border-radius: var(--radius-sm);
    background: var(--color-secondary);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s;
}

#btnCancelReconnect:hover:not(:disabled) {
    background: var(--color-secondary-dark);
}

#statusDot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #666;
}

#statusDot.connected {
    background: var(--color-success);
    box-shadow: 0 0 8px var(--color-success);
}

#statusDot.connecting {
    background: var(--color-warning);
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}


/* Output e Input */
#output {
    flex: 1;
    padding: 10px;
    overflow-y: auto;
    white-space: pre-wrap;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.4;
}

.output-line {
    margin: 0;
}

.system-message {
    color: var(--color-warning);
    font-style: italic;
    margin: 5px 0;
}

#inputArea {
    display: flex;
    border-top: 1px solid var(--border-color);
}

#inputHints {
    padding: 6px 12px 10px;
    font-size: 12px;
    color: var(--text-dim);
    background: var(--bg-darker);
    border-top: 1px solid #222;
}

#input {
    flex: 1;
    border: none;
    padding: 12px;
    font-size: 16px;
    outline: none;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: 'Courier New', monospace;
    resize: none;
    max-height: 100px;
    overflow-y: auto;
}

#input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

#input.input-flash {
    background: #1a3a1a;
    transition: background 0.1s ease-in;
}

#btnSend {
    padding: 12px 20px;
    border: none;
    background: var(--color-success);
    color: white;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    border-left: 1px solid var(--border-color);
    transition: background 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
}

#btnSend:hover:not(:disabled) {
    background: var(--color-success-dark);
}

#btnSend:active:not(:disabled) {
    background: #1e7e34;
}

#btnSend:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Modais */
#loginModal,
#confirmModal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    align-items: center;
    justify-content: center;
}

#loginModal {
    z-index: 1000;
}

#confirmModal {
    z-index: 1100;
    background: rgba(0, 0, 0, 0.85);
}

#loginModal.show,
#confirmModal.show {
    display: flex;
}

#loginForm,
#confirmBox {
    background: var(--bg-tertiary);
    padding: 24px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    min-width: 300px;
    max-width: 90%;
}

#confirmBox {
    background: var(--bg-secondary);
    min-width: 320px;
}

#loginForm h2,
#confirmBox h2 {
    margin: 0 0 20px 0;
    color: #fff;
    font-size: 20px;
}

#confirmBox h2 {
    margin-bottom: 16px;
}

#loginForm label {
    display: block;
    margin-bottom: 8px;
    color: #ccc;
    font-size: 14px;
}

#loginForm input[type="text"],
#loginForm input[type="password"] {
    width: 100%;
    padding: 10px;
    margin-bottom: 16px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 14px;
}

#loginForm input:focus {
    outline: none;
    border-color: var(--color-success);
}

.form-check {
    margin-bottom: 20px;
}

.form-check input {
    margin-right: 8px;
}

.form-check label {
    display: inline;
    cursor: pointer;
}

#loginForm button,
.confirm-actions button {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: var(--radius-sm);
    background: var(--color-success);
    color: white;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
}

#loginForm button:hover,
.confirm-actions button:hover {
    background: var(--color-success-dark);
}

#loginForm button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

#confirmText {
    margin: 0 0 20px 0;
    color: var(--text-secondary);
    font-family: 'Courier New', monospace;
    font-size: 14px;
    white-space: pre-wrap;
}

.confirm-actions {
    display: flex;
    gap: 10px;
}

.confirm-actions button {
    flex: 1;
}

.confirm-actions button.secondary {
    background: var(--color-secondary);
}

.confirm-actions button.secondary:hover {
    background: var(--color-secondary-dark);
}

/* Menus Interativos */
.menu-container {
    margin: 10px 0;
    padding: 10px;
    background: var(--bg-secondary);
    border-left: 3px solid var(--color-success);
    border-radius: var(--radius-sm);
}

.menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.menu-option {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 12px;
    margin: 4px 0;
    background: var(--bg-hover);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition-fast);
    user-select: none;
    font-family: inherit;
    font-size: 14px;
    text-align: left;
    color: inherit;
}

.menu-option:hover:not(:disabled) {
    background: var(--bg-active);
    border-color: var(--color-success);
    transform: translateX(4px);
}

.menu-option:focus,
.menu-option:focus-visible {
    outline: 2px solid var(--color-success);
    outline-offset: 2px;
    background: var(--bg-active);
}

.menu-option:active:not(:disabled) {
    transform: translateX(2px);
    background: #4a4a4a;
}

.menu-option:disabled {
    cursor: not-allowed;
    opacity: 0.6;
}

.menu-number {
    font-weight: bold;
    color: var(--color-success);
    font-family: 'Courier New', monospace;
    min-width: 30px;
}

.menu-text {
    color: var(--text-primary);
    flex: 1;
}

.menu-prompt {
    margin-top: 10px;
    padding: 8px;
    color: var(--color-warning);
    font-style: italic;
    text-align: center;
}

.menu-option-selected {
    background: var(--color-success) !important;
    border-color: var(--color-success) !important;
}

.menu-option-selected .menu-number,
.menu-option-selected .menu-text {
    color: #fff;
}

.menu-option-selected .menu-text {
    font-weight: 500;
}

.menu-inactive {
    opacity: 0.6;
    pointer-events: none;
}

#menuContainer {
    padding: 10px 16px;
    border-top: 1px solid var(--bg-hover);
}

#menuContainer:empty {
    display: none;
    padding: 0;
    border: none;
}

#menuContainer .menu-container {
    margin: 0;
}

/* Feedback de digitação para menus multi-dígito */
.menu-input-feedback {
    padding: 8px 12px;
    margin-bottom: 10px;
    background: #2a2a2a;
    border: 2px solid #ffc107;
    border-radius: 4px;
    color: #ffc107;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    font-weight: bold;
    text-align: center;
    animation: pulse 1s ease-in-out infinite;
}

.menu-input-feedback.error {
    border-color: #dc3545;
    color: #dc3545;
    animation: shake 0.3s ease-in-out;
}

.menu-input-feedback.abort {
    border-color: #6c757d;
    color: #adb5bd;
    animation: fadeOut 1.5s ease-in-out;
}

/* Buffer de entrada do menu */
.menu-input-buffer {
    position: fixed;
    bottom: 20px;
    right: 20px;
    padding: 12px 16px;
    background: #28a745;
    color: white;
    border-radius: 6px;
    font-family: 'Courier New', monospace;
    font-weight: bold;
    font-size: 18px;
    box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    z-index: 500;
    animation: bufferPulse 0.2s ease-out;
    min-width: 50px;
    text-align: center;
}

.menu-input-buffer.invalid {
    background: #dc3545;
    animation: bufferShake 0.3s;
}

.menu-input-buffer.ready {
    background: #ffc107;
    color: #000;
}

@keyframes pulse {

    0%,
    100% {
        opacity: 1;
    }

    50% {
        opacity: 0.7;
    }
}

@keyframes shake {

    0%,
    100% {
        transform: translateX(0);
    }

    25% {
        transform: translateX(-5px);
    }

    75% {
        transform: translateX(5px);
    }
}

@keyframes bufferPulse {}

@keyframes bufferShake {

    0%,
    100% {
        transform: translateX(0);
    }

    25% {
        transform: translateX(-5px);
    }

    75% {
        transform: translateX(5px);
    }
}

@keyframes fadeOut {
    0% {
        opacity: 1;
    }

    70% {
        opacity: 1;
    }

    100% {
        opacity: 0;
    }

    /* Suporte para alto contraste */
    @media (prefers-contrast: high) {
        .menu-option {
            border-width: 2px;
        }

        .menu-option:focus,
        .menu-option:focus-visible {
            outline-width: 3px;
        }
    }

    /* Suporte para modo reduzir movimento */
    @media (prefers-reduced-motion: reduce) {
        .menu-option {
            transition: none;
        }

        .menu-option:hover:not(:disabled) {
            transform: none;
        }
    }

    /* Responsividade mobile */
    @media (max-width: 768px) {
        #controls {
            gap: 8px;
            padding: 10px;
        }

        #controls button {
            padding: 8px 12px;
            font-size: 12px;
        }

        #volumeControl {
            order: 20;
            margin-left: auto;
        }

        #statusIndicator {
            order: 30;
            margin-left: 0;
            width: 100%;
        }

        #reconnectStatus {
            order: 31;
            width: 100%;
        }

        #output {
            font-size: 13px;
        }
    }

    @media (max-width: 480px) {
        #volumeSlider {
            width: 60px;
        }

        #volumeValue {
            font-size: 11px;
            min-width: 32px;
        }
    }